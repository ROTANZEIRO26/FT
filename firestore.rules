rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCheck(data) {
      return data.fullName is string && data.fullName.size() <= 200 &&
             data.cpf is string && data.cpf.size() <= 14 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /checks/{checkId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(checkId);
      allow create: if isSignedIn() && isValidId(checkId) && isValidCheck(request.resource.data);
      allow update: if isSignedIn() && isValidId(checkId) && 
                    resource.data.createdBy == request.auth.uid && 
                    request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if false;
    }
  }
}
