rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCheck(data) {
      return data.fullName is string && data.fullName.size() <= 200 &&
             data.cpf is string && data.cpf.size() <= 14 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /checks/{checkId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCheck(request.resource.data);
      // No updates or deletes for audit trail integrity? 
      // User didn't ask for update/delete, so I'll restrict it for security.
      allow update, delete: if false;
    }
  }
}
